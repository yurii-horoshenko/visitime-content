# =============================================================
# VisiTime Content — Access Tokens Template
# =============================================================
# 1. Скопируй этот файл в .env:    cp .env.example .env
# 2. Заполни реальные значения в .env (НЕ в этом файле!)
# 3. .env уже в .gitignore — не коммитится в git
# 4. Инструкции как получить каждый токен: docs/ops/credentials-setup.md
# =============================================================


# --- ПРОЕКТНЫЙ ТРЕКЕР ---
# Уже настроено, оставь как есть
LINEAR_API_KEY=
LINEAR_TEAM_ID=2b130448-21d2-4167-9313-06187182a62e
LINEAR_TEAM_KEY=VIS


# =============================================================
# PRIORITY 1 — LinkedIn (основной B2B канал)
# =============================================================
# Где получить: https://www.linkedin.com/developers/apps
# Инструкция: docs/ops/credentials-setup.md#linkedin
# Scopes нужны: w_member_social, w_organization_social, r_organization_social
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_REFRESH_TOKEN=
LINKEDIN_PERSON_URN=                # Твой личный URN (для постов от имени Yurii)
LINKEDIN_COMPANY_PAGE_ID=           # VisiTime Company Page URN (после создания)


# =============================================================
# PRIORITY 1 — Meta (Facebook Page + Instagram Business)
# =============================================================
# Где получить: https://developers.facebook.com/apps + Meta Business Manager
# Инструкция: docs/ops/credentials-setup.md#meta
# Один Page Access Token работает для FB Page и IG Business
META_APP_ID=
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=             # Long-lived, получается из short через refresh
META_PAGE_ID=                       # ID FB Page «VisiTime»
META_IG_BUSINESS_ACCOUNT_ID=        # ID Instagram Business (привязан к FB Page)


# =============================================================
# PRIORITY 2 — YouTube + Google Business Profile
# =============================================================
# Где получить: https://console.cloud.google.com/
# Инструкция: docs/ops/credentials-setup.md#google
# Один OAuth работает для YouTube Data API и Business Profile API
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=                 # @visitime channel ID
GMB_ACCOUNT_ID=                     # Google Business Profile account
GMB_LOCATION_ID=                    # VisiTime location ID


# =============================================================
# PRIORITY 3 — Twitter/X (ОПЦИОНАЛЬНО — платный API $200/мес)
# =============================================================
# Где получить: https://developer.twitter.com/
# Инструкция: docs/ops/credentials-setup.md#twitter
# Альтернатива: публиковать в Twitter вручную (5 мин в неделю)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BEARER_TOKEN=


# =============================================================
# PRIORITY 4 — TikTok (требует одобрения приложения, 2-4 недели)
# =============================================================
# Где получить: https://developers.tiktok.com/
# Инструкция: docs/ops/credentials-setup.md#tiktok
# Альтернатива на старте: Metricool (OAuth, без approval)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=
TIKTOK_OPEN_ID=

# --- Metricool (TikTok fallback) ---
METRICOOL_API_KEY=
METRICOOL_USER_ID=


# =============================================================
# GA4 + ANALYTICS (для Фазы 0 — weekly reports)
# =============================================================
# Где получить: GA4 → Admin → Service Account
GA4_PROPERTY_ID=
GA4_SERVICE_ACCOUNT_JSON_PATH=./secrets/ga4-service-account.json


# =============================================================
# ORCHESTRATOR (n8n / Make.com)
# =============================================================
# Если используешь self-hosted n8n или cloud
N8N_WEBHOOK_URL=
N8N_API_KEY=


# =============================================================
# AUTOMATION / AI
# =============================================================
# Anthropic для AI-агентов (если вне Claude Code)
ANTHROPIC_API_KEY=

# Cloudflare Email Routing (не токен — просто referentce)
CLOUDFLARE_EMAIL_ROUTING_DOMAIN=visitime.app
